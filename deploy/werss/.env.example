# Replace this with a POC-verified immutable version tag or image digest.
WERSS_IMAGE=ghcr.io/replace-with-owner/werss:replace-with-pinned-tag
WERSS_PORT=8001

# Existing external MySQL. For MySQL on this Windows host, use host.docker.internal.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=werss
MYSQL_USER=werss_app
MYSQL_PASSWORD=replace-with-a-strong-local-secret
